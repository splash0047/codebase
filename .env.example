# PostgreSQL
POSTGRES_USER=ckai
POSTGRES_PASSWORD=ckai_secret
POSTGRES_DB=codebase_knowledge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/ckai_secret
NEO4J_USER=neo4j
NEO4J_PASSWORD=ckai_secret

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── AI Models ─────────────────────────────────────────────────────────────────
# Either OpenAI or Gemini API key is required.
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_key_here
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone Configuration (Required if VECTOR_STORE=pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=codebase-knowledge

# OpenTelemetry Configuration (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# App
APP_ENV=development
APP_SECRET_KEY=change_me_in_production
LOG_LEVEL=INFO

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Adaptive Hard Limits (Override defaults)
MAX_NODES_ABSOLUTE=50
MAX_TOKENS_ABSOLUTE=4000
MAX_RETRIES=3
MAX_TRAVERSAL_DEPTH=2

# Cache Budget
CACHE_BUDGET_PER_REPO_MB=50
CACHE_LRU_MAX_ITEMS=1000
